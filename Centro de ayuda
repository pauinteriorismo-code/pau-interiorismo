            <div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="font-size:12px;color:var(--text-soft)">IVA repercutido</span><span style="font-weight:700">4.832€</span></div>
            <div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="font-size:12px;color:var(--text-soft)">IVA deducible</span><span style="font-weight:700;color:#2d7a52">1.864€</span></div>
            <div style="display:flex;justify-content:space-between"><span style="font-size:12px;color:var(--text-soft)">A ingresar</span><span style="font-weight:700;color:var(--navy)">2.968€</span></div>
